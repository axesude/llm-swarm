# LLM Swarm Orchestrator - Environment Variables Template
# Copy this file to .env and fill in your values.

# --- Backend Configuration ---
# Port for the Express API server
BACKEND_PORT=3001

# --- WebSocket Configuration ---
# Port for the WebSocket server (real-time streaming and health updates)
WEBSOCKET_PORT=8080
# Basic authentication token required for client WebSocket connections
# Pass this as a query param: ws://localhost:8080?token=YOUR_SECRET_TOKEN
WEBSOCKET_AUTH_TOKEN=swarm_secret_access_token_123

# --- Gemini CLI Configuration ---
# Absolute path to the installed 'gemini' CLI binary
GEMINI_CLI_PATH=/usr/local/bin/gemini
# Base directory where agent OAuth .json credential files are stored
# Files should be named like: agent1.json, agent2.json, etc.
AGENT_CREDENTIALS_BASE_PATH=./backend/credentials

# --- Storage Configuration ---
# Path to the SQLite database file for quota tracking and persistence
SQLITE_DB_PATH=./backend/db/swarm.db

# --- Abuse Prevention: Daily Quota ---
# Hard cap on the number of requests an agent can make per 24-hour period
DAILY_QUOTA_LIMIT=1000
# Usage percentage (0.0 to 1.0) at which to emit a warning log
QUOTA_WARNING_THRESHOLD=0.75

# --- Abuse Prevention: Rate Limiting ---
# Maximum requests allowed per minute per agent (Token Bucket algorithm)
MAX_REQUESTS_PER_MINUTE=10
# Minimum random jitter delay (ms) added between agent calls
JITTER_MIN_MS=2000
# Maximum random jitter delay (ms) added between agent calls
JITTER_MAX_MS=5000

# --- Abuse Prevention: Circuit Breaker ---
# Number of consecutive failures before the agent's circuit trips to OPEN
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# Duration (ms) the circuit remains OPEN before testing recovery (HALF-OPEN)
CIRCUIT_BREAKER_COOLDOWN_MS=60000

# --- Frontend Configuration (for reference) ---
# Port for the Next.js development server
FRONTEND_PORT=3000
